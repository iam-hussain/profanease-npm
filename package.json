{
  "name": "profanease",
  "version": "2.0.1",
  "description": "Modern, lightweight profanity detection & content moderation toolkit with l33t speak detection, multi-language support, and guard rails",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./langs/*": {
      "import": {
        "types": "./dist/langs/*.d.ts",
        "default": "./dist/langs/*.js"
      },
      "require": {
        "types": "./dist/langs/*.d.cts",
        "default": "./dist/langs/*.cjs"
      }
    }
  },
  "bin": {
    "profanease-mcp": "./dist/mcp-server.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.cjs",
    "dist/**/*.d.ts",
    "dist/**/*.d.cts",
    "!dist/**/*.map",
    "llms.txt",
    "llms-full.txt"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build && npm test",
    "typecheck": "tsc --noEmit",
    "release": "npm version patch && git push && git push --tags",
    "release:minor": "npm version minor && git push && git push --tags",
    "release:major": "npm version major && git push && git push --tags"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iam-hussain/profanease-npm.git"
  },
  "keywords": [
    "profanity",
    "profanity-filter",
    "content-moderation",
    "guard-rails",
    "bad-words",
    "profanease",
    "leet-speak",
    "multi-language",
    "text-filter",
    "censorship",
    "moderation",
    "clean",
    "check",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "ai",
    "llm",
    "ai-safety",
    "ai-guardrails"
  ],
  "author": "iam-hussain",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/iam-hussain/profanease-npm/issues"
  },
  "homepage": "https://github.com/iam-hussain/profanease-npm#readme",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "eslint": "^10.0.0",
    "prettier": "^3.5.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.33.0",
    "vitest": "^4.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "optionalDependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.25.76"
  }
}
