{
  "name": "profanease",
  "version": "2.0.0",
  "description": "Modern, lightweight profanity detection & content moderation toolkit with l33t speak detection, multi-language support, and guard rails",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./langs/*": {
      "import": {
        "types": "./dist/langs/*.d.ts",
        "default": "./dist/langs/*.js"
      },
      "require": {
        "types": "./dist/langs/*.d.cts",
        "default": "./dist/langs/*.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build && npm test",
    "typecheck": "tsc --noEmit",
    "release": "npm version patch && git push && git push --tags",
    "release:minor": "npm version minor && git push && git push --tags",
    "release:major": "npm version major && git push && git push --tags"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZaHuPro/Profanease.git"
  },
  "keywords": [
    "profanity",
    "profanity-filter",
    "content-moderation",
    "guard-rails",
    "bad-words",
    "profanease",
    "leet-speak",
    "multi-language",
    "text-filter",
    "censorship",
    "moderation",
    "clean",
    "check"
  ],
  "author": "ZaHuPro",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/ZaHuPro/Profanease/issues"
  },
  "homepage": "https://github.com/ZaHuPro/Profanease#readme",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
